{
  "manifest_version": 3,
  "name": "PagePost",
  "version": "1.0.0",
  "description": "Contextual sticky notes for the web.",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "sidePanel",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/index.tsx"
      ],
      "css": [
        "src/content/style.css"
      ]
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/navigationPatch.ts"
      ],
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "index.html"
  },
  "side_panel": {
    "default_path": "index.html"
  }
}