{
    "manifest_version": 3,
    "name": "PagePost - Contextual Web Notes & Markup",
    "version": "1.0.0",
    "description": "Add sticky notes and markup directly on any webpage and manage them in one place",
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "permissions": [
        "storage",
        "activeTab",
        "contextMenus",
        "sidePanel",
        "tabs",
        "webNavigation"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "src/background/index.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content/index.js"
            ],
            "css": [
                "src/content/style.css"
            ]
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content/navigationPatch.js"
            ],
            "world": "MAIN"
        }
    ],
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "side_panel": {
        "default_path": "index.html"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icon16.png",
                "icon48.png",
                "icon128.png"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}